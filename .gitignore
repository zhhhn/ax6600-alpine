# 排除大文件和构建产物
build/linux-6.6.22/
build/alpine-rootfs/
build/initramfs-minimal/
*.tar.xz
*.tar.gz
*.bin
*.itb

# 保留必要的配置文件
!configs/
!rootfs-overlay/
!scripts/

# 保留GitHub Actions工作流
!.github/
!.github/workflows/
!.github/workflows/*.yml
!.github/*.md

# 排除文档（但保留关键文档）
*.md
!README.md
!INSTALL.md
!MANIFEST.md
!GITHUB_SETUP.md
!PUSH_TO_GITHUB.md
!PRODUCTION_BUILD.md
!BUILD_STATUS.md
!CHECKLIST.md
!CRON.md
!PROGRESS.md
!PROJECT.md
!READY.md

# 脚本
*.sh
!build.sh
!auto-dev.sh
!scripts/*.sh

# 设备树
*.dts
*.dtb
!configs/*.dts
!configs/*.dtb

# 固件输出（用户自行构建）
out/*.bin
out/*.itb
out/*.img
out/*.gz