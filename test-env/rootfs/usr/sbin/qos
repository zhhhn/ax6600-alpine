#!/bin/sh
# QoS/Traffic Control utility for JDCloud AX6600
# Manage bandwidth limits using tc (traffic control)

TC="/sbin/tc"
QOS_CONF="/etc/qos.conf"

usage() {
    echo "Usage: qos <command> [options]"
    echo "Commands:"
    echo "  set <download-mbps> <upload-mbps>  - Set bandwidth limits"
    echo "  clear                              - Clear all QoS rules"
    echo "  status                             - Show QoS status"
    echo "  enable                             - Enable QoS service"
    echo "  disable                            - Disable QoS service"
    echo "  priority <ip> <level>              - Set IP priority (1-10)"
    echo "  limit <ip> <download> <upload>     - Limit specific IP"
}

qos_set() {
    local download="$1"
    local upload="$2"
    
    if [ -z "$download" ] || [ -z "$upload" ]; then
        echo "Error: Download and upload speeds required (in Mbps)"
        echo "Example: qos set 100 50  (100 Mbps download, 50 Mbps upload)"
        exit 1
    fi
    
    echo "Setting QoS: ${download} Mbps down, ${upload} Mbps up"
    
    # Save configuration
    mkdir -p /etc
    cat > "$QOS_CONF" << EOF
# QoS Configuration
DOWNLOAD=${download}
UPLOAD=${upload}
EOF
    
    # Apply tc rules
    if ! command -v tc > /dev/null; then
        echo "Error: tc (traffic control) not available"
        echo "Install: apk add iproute2-tc"
        exit 1
    fi
    
    # Convert Mbps to Kbps
    local dl_kbps=$((download * 1000))
    local ul_kbps=$((upload * 1000))
    
    # Setup download (ingress on WAN)
    echo "Configuring download shaping..."
    
    # Clear existing
    $TC qdisc del dev eth0 ingress 2>/dev/null || true
    
    # Add ingress qdisc
    $TC qdisc add dev eth0 ingress handle 10:
    
    # Rate limit ingress using IFB (if available)
    # Simplified approach: use police filter
    $TC filter add dev eth0 ingress protocol ip prio 1 \
        police rate ${dl_kbps}kbit burst ${dl_kbps}kbit drop flowid :10
    
    # Setup upload (egress on WAN)
    echo "Configuring upload shaping..."
    
    # Clear existing
    $TC qdisc del dev eth0 root 2>/dev/null || true
    
    # Add HTB qdisc for egress
    $TC qdisc add dev eth0 root handle 1: htb default 10
    $TC class add dev eth0 parent 1: classid 1:1 htb rate ${ul_kbps}kbit ceil ${ul_kbps}kbit
    
    # Default class (all traffic)
    $TC class add dev eth0 parent 1:1 classid 1:10 htb rate $((ul_kbps / 2))kbit ceil ${ul_kbps}kbit prio 2
    
    # High priority class (SSH, DNS, etc)
    $TC class add dev eth0 parent 1:1 classid 1:20 htb rate $((ul_kbps / 4))kbit ceil ${ul_kbps}kbit prio 1
    
    # Bulk/low priority class
    $TC class add dev eth0 parent 1:1 classid 1:30 htb rate $((ul_kbps / 4))kbit ceil ${ul_kbps}kbit prio 3
    
    # Filter for high priority (SSH, DNS)
    $TC filter add dev eth0 parent 1: protocol ip prio 1 u32 \
        match ip dport 22 0xffff flowid 1:20
    $TC filter add dev eth0 parent 1: protocol ip prio 1 u32 \
        match ip dport 53 0xffff flowid 1:20
    
    # Filter for bulk traffic (large transfers)
    $TC filter add dev eth0 parent 1: protocol ip prio 3 u32 \
        match ip dport 80 0xffff flowid 1:30
    $TC filter add dev eth0 parent 1: protocol ip prio 3 u32 \
        match ip dport 443 0xffff flowid 1:30
    
    echo "QoS applied successfully"
    qos_status
}

qos_clear() {
    echo "Clearing QoS rules..."
    
    $TC qdisc del dev eth0 root 2>/dev/null || true
    $TC qdisc del dev eth0 ingress 2>/dev/null || true
    $TC qdisc del dev br-lan root 2>/dev/null || true
    
    rm -f "$QOS_CONF"
    
    echo "QoS rules cleared"
}

qos_status() {
    echo "=== QoS Status ==="
    echo ""
    
    if [ -f "$QOS_CONF" ]; then
        echo "Configuration:"
        cat "$QOS_CONF"
    else
        echo "Configuration: Not configured"
    fi
    echo ""
    
    if command -v tc > /dev/null; then
        echo "Egress (upload) rules:"
        $TC qdisc show dev eth0 2>/dev/null || echo "  No egress rules"
        echo ""
        echo "Classes:"
        $TC class show dev eth0 2>/dev/null | head -10 || echo "  No classes"
        echo ""
        echo "Ingress (download) rules:"
        $TC qdisc show dev eth0 ingress 2>/dev/null || echo "  No ingress rules"
    else
        echo "tc not available"
    fi
}

qos_enable() {
    echo "Enabling QoS service..."
    
    if [ -f "$QOS_CONF" ]; then
        local dl=$(grep DOWNLOAD "$QOS_CONF" | cut -d= -f2)
        local ul=$(grep UPLOAD "$QOS_CONF" | cut -d= -f2)
        qos_set "$dl" "$ul"
    else
        echo "Error: No configuration found"
        echo "Run: qos set <download> <upload>"
        exit 1
    fi
    
    # Create init script
    cat > /etc/init.d/qos << 'EOF'
#!/sbin/openrc-run

name="qos"
depend() {
    after net
}

start() {
    ebegin "Starting QoS"
    [ -f /etc/qos.conf ] && /usr/sbin/qos set \
        $(grep DOWNLOAD /etc/qos.conf | cut -d= -f2) \
        $(grep UPLOAD /etc/qos.conf | cut -d= -f2)
    eend $?
}

stop() {
    ebegin "Stopping QoS"
    /usr/sbin/qos clear
    eend $?
}
EOF
    chmod +x /etc/init.d/qos
    
    rc-update add qos default 2>/dev/null || true
    
    echo "QoS service enabled"
}

qos_disable() {
    echo "Disabling QoS service..."
    
    qos_clear
    rc-update del qos default 2>/dev/null || true
    
    echo "QoS service disabled"
}

qos_priority() {
    local ip="$1"
    local level="${2:-5}"
    
    if [ -z "$ip" ]; then
        echo "Error: IP address required"
        exit 1
    fi
    
    # Priority levels: 1=highest, 10=lowest
    # Map to HTB class
    local class=$((10 + level))
    
    echo "Setting priority for $ip to level $level"
    
    # Add filter for this IP
    $TC filter add dev eth0 parent 1: protocol ip prio ${level} u32 \
        match ip src ${ip} flowid 1:${class}
    
    echo "Priority set"
}

qos_limit_ip() {
    local ip="$1"
    local download="$2"
    local upload="${3:-$download}"
    
    if [ -z "$ip" ] || [ -z "$download" ]; then
        echo "Error: IP and download speed required"
        exit 1
    fi
    
    local dl_kbps=$((download * 1000))
    local ul_kbps=$((upload * 1000))
    
    echo "Limiting $ip to ${download} Mbps down, ${upload} Mbps up"
    
    # Create class for this IP
    local class_num=$(date +%s | tail -c3)
    
    $TC class add dev eth0 parent 1:1 classid 1:${class_num} htb \
        rate ${ul_kbps}kbit ceil ${ul_kbps}kbit
    
    $TC filter add dev eth0 parent 1: protocol ip prio 5 u32 \
        match ip src ${ip} flowid 1:${class_num}
    
    echo "IP limited"
}

# Main
case "$1" in
    set)
        qos_set "$2" "$3"
        ;;
    clear)
        qos_clear
        ;;
    status)
        qos_status
        ;;
    enable)
        qos_enable
        ;;
    disable)
        qos_disable
        ;;
    priority)
        qos_priority "$2" "$3"
        ;;
    limit)
        qos_limit_ip "$2" "$3" "$4"
        ;;
    *)
        usage
        exit 1
        ;;
esac