# KMS Server Package for JDCloud AX6600
# APKBUILD for kms-server

pkgname=kms-server
pkgver=1.0.0
pkgrel=0
pkgdesc="KMS activation server for Windows/Office"
url="https://github.com/openclaw/clawui"
arch="noarch"
license="MIT"
depends="clawui"
options="!check"
source=""

package() {
    # Create app directory
    mkdir -p "$pkgdir/usr/share/clawui/apps/kms"
    mkdir -p "$pkgdir/usr/share/kms"
    mkdir -p "$pkgdir/etc/init.d"
    mkdir -p "$pkgdir/etc/conf.d"
    
    # Copy app files
    cp -r "$srcdir"/www/* "$pkgdir/usr/share/clawui/apps/kms/" 2>/dev/null || true
    cp -r "$srcdir"/api "$pkgdir/usr/share/clawui/apps/kms/" 2>/dev/null || true
    cp -r "$srcdir"/i18n "$pkgdir/usr/share/clawui/apps/kms/" 2>/dev/null || true
    
    # Copy manifest
    cp "$srcdir"/manifest.json "$pkgdir/usr/share/clawui/apps/kms/" 2>/dev/null || true
    
    # Copy KMS server script
    cp "$srcdir/kms-server.sh" "$pkgdir/usr/share/kms/" 2>/dev/null || true
    chmod +x "$pkgdir/usr/share/kms/kms-server.sh"
    
    # Install init script
    cp "$srcdir/kms-server.init" "$pkgdir/etc/init.d/kms-server"
    chmod +x "$pkgdir/etc/init.d/kms-server"
    
    # Install config
    cp "$srcdir/kms-server.conf" "$pkgdir/etc/conf.d/kms-server"
}

sha512sums=""
