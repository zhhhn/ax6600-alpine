# ClawUI App Package Template
# APKBUILD for clawui-app-wireguard

pkgname=clawui-app-wireguard
pkgver=1.0.0
pkgrel=0
pkgdesc="ClawUI web interface for WireGuard VPN"
url="https://github.com/openclaw/clawui"
arch="noarch"
license="MIT"
depends="clawui wireguard-tools"
source=""
subpackages="$pkgname-lang"

package() {
    # Create app directory
    mkdir -p "$pkgdir/usr/share/clawui/apps/wireguard"
    
    # Copy app files
    cp -r "$srcdir"/www/* "$pkgdir/usr/share/clawui/apps/wireguard/" 2>/dev/null || true
    cp -r "$srcdir"/api "$pkgdir/usr/share/clawui/apps/wireguard/" 2>/dev/null || true
    cp -r "$srcdir"/i18n "$pkgdir/usr/share/clawui/apps/wireguard/" 2>/dev/null || true
    
    # Copy manifest
    cp "$srcdir"/manifest.json "$pkgdir/usr/share/clawui/apps/wireguard/" 2>/dev/null || true
}

lang() {
    mkdir -p "$subpkgdir/usr/share/clawui/apps/wireguard/i18n"
    cp -r "$srcdir"/i18n/* "$subpkgdir/usr/share/clawui/apps/wireguard/i18n/" 2>/dev/null || true
}

sha512sums=""