# Aria2 Download Manager Package for JDCloud AX6600
# APKBUILD for aria2

pkgname=aria2
pkgver=1.37.0
pkgrel=1
pkgdesc="Aria2 download manager with ClawUI integration"
url="https://github.com/openclaw/clawui"
arch="aarch64"
license="GPL-2.0-or-later"
depends="clawui aria2"
options="!check"
source=""

package() {
    # Create app directory
    mkdir -p "$pkgdir/usr/share/clawui/apps/aria2"
    mkdir -p "$pkgdir/etc/init.d"
    mkdir -p "$pkgdir/etc/conf.d"
    mkdir -p "$pkgdir/etc/aria2"
    mkdir -p "$pkgdir/var/lib/aria2"
    
    # Copy app files
    cp -r "$srcdir"/www/* "$pkgdir/usr/share/clawui/apps/aria2/" 2>/dev/null || true
    cp -r "$srcdir"/api "$pkgdir/usr/share/clawui/apps/aria2/" 2>/dev/null || true
    cp -r "$srcdir"/i18n "$pkgdir/usr/share/clawui/apps/aria2/" 2>/dev/null || true
    
    # Copy manifest
    cp "$srcdir"/manifest.json "$pkgdir/usr/share/clawui/apps/aria2/" 2>/dev/null || true
    
    # Install config
    cp "$srcdir/aria2.conf" "$pkgdir/etc/aria2/aria2.conf"
    
    # Install init script
    cp "$srcdir/aria2.init" "$pkgdir/etc/init.d/aria2"
    chmod +x "$pkgdir/etc/init.d/aria2"
    
    # Install config for conf.d
    cp "$srcdir/aria2.conf.default" "$pkgdir/etc/conf.d/aria2"
}

sha512sums=""
