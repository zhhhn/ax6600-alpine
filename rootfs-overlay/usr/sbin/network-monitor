#!/bin/sh
# Network monitoring utility for JDCloud AX6600

MONITOR_DIR="/var/lib/network-monitor"
TRAFFIC_LOG="${MONITOR_DIR}/traffic.log"
ALERT_LOG="${MONITOR_DIR}/alerts.log"

usage() {
    echo "Usage: network-monitor <command> [options]"
    echo "Commands:"
    echo "  start           - Start traffic monitoring"
    echo "  stop            - Stop monitoring"
    echo "  status          - Show current status"
    echo "  report          - Generate traffic report"
    echo "  top             - Show top bandwidth users"
    echo "  alert <MB>      - Set bandwidth alert threshold"
}

start_monitor() {
    mkdir -p "$MONITOR_DIR"
    
    echo "Starting network monitor..."
    
    # Create monitor daemon
    cat > /usr/sbin/netmon-daemon << 'DAEMON'
#!/bin/sh
MONITOR_DIR="/var/lib/network-monitor"
TRAFFIC_LOG="${MONITOR_DIR}/traffic.log"

mkdir -p "$MONITOR_DIR"

# Initialize counters
PREV_RX=$(cat /proc/net/dev | grep eth0 | awk '{print $2}')
PREV_TX=$(cat /proc/net/dev | grep eth0 | awk '{print $10}')

while true; do
    sleep 60
    
    # Get current values
    CURR_RX=$(cat /proc/net/dev | grep eth0 | awk '{print $2}')
    CURR_TX=$(cat /proc/net/dev | grep eth0 | awk '{print $10}')
    
    # Calculate delta (bytes per minute)
    DELTA_RX=$((CURR_RX - PREV_RX))
    DELTA_TX=$((CURR_TX - PREV_TX))
    
    # Convert to MB
    RX_MB=$((DELTA_RX / 1024 / 1024))
    TX_MB=$((DELTA_TX / 1024 / 1024))
    
    # Log
    TIMESTAMP=$(date '+%Y-%m-%d %H:%M')
    echo "${TIMESTAMP} RX=${RX_MB}MB TX=${TX_MB}MB" >> "$TRAFFIC_LOG"
    
    # Update previous
    PREV_RX=$CURR_RX
    PREV_TX=$CURR_TX
    
    # Rotate log if too large
    if [ $(wc -l < "$TRAFFIC_LOG") -gt 10080 ]; then
        tail -10080 "$TRAFFIC_LOG" > "${TRAFFIC_LOG}.tmp"
        mv "${TRAFFIC_LOG}.tmp" "$TRAFFIC_LOG"
    fi
done
DAEMON
    
    chmod +x /usr/sbin/netmon-daemon
    /usr/sbin/netmon-daemon &
    
    echo "Network monitor started"
}

stop_monitor() {
    echo "Stopping network monitor..."
    killall netmon-daemon 2>/dev/null || true
    echo "Network monitor stopped"
}

show_status() {
    echo "=== Network Monitor Status ==="
    
    if pgrep -f netmon-daemon > /dev/null; then
        echo "Status: running"
    else
        echo "Status: not running"
    fi
    
    echo ""
    echo "Current traffic:"
    echo "  Download: $(cat /proc/net/dev | grep eth0 | awk '{printf "%.2f MB", $2/1024/1024}')"
    echo "  Upload: $(cat /proc/net/dev | grep eth0 | awk '{printf "%.2f MB", $10/1024/1024}')"
    
    if [ -f "$TRAFFIC_LOG" ]; then
        echo ""
        echo "Last 5 minutes:"
        tail -5 "$TRAFFIC_LOG"
    fi
}

show_report() {
    local hours="${1:-24}"
    
    echo "=== Traffic Report (last ${hours} hours) ==="
    
    if [ ! -f "$TRAFFIC_LOG" ]; then
        echo "No data available"
        exit 1
    fi
    
    local lines=$((hours * 60))
    local data=$(tail -$lines "$TRAFFIC_LOG")
    
    # Calculate totals
    local total_rx=0
    local total_tx=0
    
    while read line; do
        rx=$(echo "$line" | grep -o 'RX=[0-9]*' | cut -d= -f2)
        tx=$(echo "$line" | grep -o 'TX=[0-9]*' | cut -d= -f2)
        total_rx=$((total_rx + rx))
        total_tx=$((total_tx + tx))
    done <<< "$data"
    
    echo "Total Download: ${total_rx} MB"
    echo "Total Upload: ${total_tx} MB"
    echo "Total: $((total_rx + total_tx)) MB"
    
    echo ""
    echo "Hourly breakdown:"
    echo "$data" | awk '{print $1}' | uniq -c | head -24
}

show_top() {
    echo "=== Top Bandwidth Users ==="
    
    # Check for nethogs or iftop
    if command -v nethogs > /dev/null; then
        echo "Use: nethogs eth0"
    elif command -v iftop > /dev/null; then
        echo "Use: iftop -i eth0"
    else
        echo "Install nethogs or iftop for per-process traffic"
        echo "  apk add nethogs"
        echo "  apk add iftop"
    fi
    
    echo ""
    echo "Current connections:"
    netstat -tn | awk '{print $5}' | cut -d: -f1 | sort | uniq -c | sort -rn | head -10
}

set_alert() {
    local threshold="$1"
    
    if [ -z "$threshold" ]; then
        echo "Current alert threshold: $(cat ${MONITOR_DIR}/threshold 2>/dev/null || echo 'not set')"
        exit 0
    fi
    
    echo "$threshold" > "${MONITOR_DIR}/threshold"
    echo "Alert threshold set to ${threshold} MB/minute"
}

# Main
case "$1" in
    start) start_monitor ;;
    stop) stop_monitor ;;
    status) show_status ;;
    report) show_report "$2" ;;
    top) show_top ;;
    alert) set_alert "$2" ;;
    *) usage ;;
esac