#!/bin/sh
# PPPoE configuration utility for JDCloud AX6600
# Setup PPPoE for broadband connections

PPP_DIR="/etc/ppp"
PPP_PEERS="${PPP_DIR}/peers"
PPP_OPTIONS="${PPP_DIR}/options"
PPP_PAP="${PPP_DIR}/pap-secrets"
PPP_CHAP="${PPP_DIR}/chap-secrets"

usage() {
    echo "Usage: pppoe-setup <command> [options]"
    echo "Commands:"
    echo "  config <username> <password>  - Configure PPPoE"
    echo "  connect                       - Start PPPoE connection"
    echo "  disconnect                    - Stop PPPoE connection"
    echo "  status                        - Show connection status"
    echo "  test                          - Test PPPoE discovery"
    echo "  enable                        - Enable PPPoE on boot"
    echo "  disable                       - Disable PPPoE on boot"
}

ensure_dirs() {
    mkdir -p "$PPP_PEERS"
}

pppoe_config() {
    local username="$1"
    local password="$2"
    
    if [ -z "$username" ] || [ -z "$password" ]; then
        echo "Error: Username and password required"
        exit 1
    fi
    
    ensure_dirs
    
    echo "Configuring PPPoE..."
    echo "Username: $username"
    
    # Create PPPoE peer configuration
    cat > "${PPP_PEERS}/pppoe" << 'EOF'
# PPPoE configuration for JDCloud AX6600

# Connection name
name "dsl-provider"

# Use PPPoE plugin
plugin pppoe.so

# Interface for PPPoE (WAN port)
eth0

# No auth required from ISP
noauth

# Persist on failure
persist
holdoff 10
maxfail 3

# LCP echo requests
lcp-echo-interval 10
lcp-echo-failure 3

# Default route
defaultroute
replacedefaultroute

# Use peer DNS
usepeerdns

# MTU for PPPoE (usually 1492)
mtu 1492
mru 1492

# IP settings
noipdefault
ipcp-accept-local
ipcp-accept-remote

# Compression
nodeflate
noccp
novj
novjccomp
nobsdcomp

# Debug (disable for production)
# debug

# Lock device
lock

# Timeout
connect-delay 5000
EOF
    
    # Set username in config
    sed -i "s/^name .*/name \"${username}\"/" "${PPP_PEERS}/pppoe"
    
    # Create secrets files
    echo "# PPPoE secrets" > "$PPP_PAP"
    echo "${username} * ${password}" >> "$PPP_PAP"
    
    echo "# PPPoE secrets" > "$PPP_CHAP"
    echo "${username} * ${password}" >> "$PPP_CHAP"
    
    chmod 600 "$PPP_PAP" "$PPP_CHAP"
    
    # Create PPPoE options
    cat > "$PPP_OPTIONS" << 'EOF'
# Global PPP options
lock
usepeerdns
defaultroute
EOF
    
    # Create network interface for PPPoE
    cat > "/etc/network/interfaces.d/pppoe" << 'EOF'
# PPPoE interface
auto pppoe
iface pppoe inet ppp
    pre-up /sbin/ip link set eth0 up
    provider pppoe
EOF
    
    # Update WAN interface to not use DHCP
    sed -i '/^auto eth0/,/^$/s/^iface eth0 inet dhcp.*$/iface eth0 inet manual/' \
        /etc/network/interfaces 2>/dev/null || true
    
    echo "PPPoE configured successfully"
    echo "Run 'pppoe-connect' to start connection"
}

pppoe_connect() {
    echo "Starting PPPoE connection..."
    
    if [ ! -f "${PPP_PEERS}/pppoe" ]; then
        echo "Error: PPPoE not configured"
        echo "Run: pppoe-setup config <username> <password>"
        exit 1
    fi
    
    # Bring up WAN interface
    ip link set eth0 up
    
    # Start PPPoE
    if command -v pppd > /dev/null; then
        pppd call pppoe updetach &
        sleep 5
        
        # Check connection
        if ip addr show ppp0 2>/dev/null; then
            echo "PPPoE connected!"
            echo "Interface: ppp0"
            echo "IP: $(ip addr show ppp0 | grep 'inet ' | awk '{print $2}')"
        else
            echo "Connection attempt started, check status in 10 seconds"
        fi
    else
        echo "Error: pppd not installed"
        echo "Install: apk add ppp"
        exit 1
    fi
}

pppoe_disconnect() {
    echo "Stopping PPPoE connection..."
    
    # Kill PPPoE process
    killall pppd 2>/dev/null || true
    
    # Bring down interface
    ip link set ppp0 down 2>/dev/null || true
    
    echo "PPPoE disconnected"
}

pppoe_status() {
    echo "=== PPPoE Status ==="
    echo ""
    
    # Check if configured
    if [ -f "${PPP_PEERS}/pppoe" ]; then
        echo "Configuration: Yes"
        echo "Username: $(grep '^name' ${PPP_PEERS}/pppoe | awk '{print $2}' | tr -d '"')"
    else
        echo "Configuration: No"
    fi
    echo ""
    
    # Check connection
    if ip addr show ppp0 2>/dev/null; then
        echo "Status: Connected"
        echo "Interface: ppp0"
        echo "Local IP: $(ip addr show ppp0 | grep 'inet ' | awk '{print $2}')"
        echo "Peer IP: $(ip addr show ppp0 | grep 'inet ' | awk '{print $4}' | cut -d/ -f1)"
        
        # Check default route
        if ip route | grep -q ppp0; then
            echo "Default route: via ppp0"
        fi
        
        # Connection time
        local uptime=$(ps aux | grep pppd | grep -v grep | awk '{print $9}')
        [ -n "$uptime" ] && echo "Started: $uptime"
    else
        echo "Status: Not connected"
        
        # Check if process running
        if pgrep pppd > /dev/null; then
            echo "Note: pppd process running but no interface"
        fi
    fi
}

pppoe_test() {
    echo "Testing PPPoE discovery..."
    
    if command -v pppoe-discovery > /dev/null; then
        pppoe-discovery -I eth0
    elif command -v pppd > /dev/null; then
        # Use pppd for discovery
        echo "Attempting PPPoE discovery on eth0..."
        pppd pty 'pppoe -I eth0' nodetach noauth debug 2>&1 | head -20 &
        sleep 5
        killall pppd 2>/dev/null || true
    else
        echo "pppoe-discovery not available"
        echo "Install: apk add ppp rp-pppoe"
    fi
}

pppoe_enable() {
    echo "Enabling PPPoE auto-connect on boot..."
    
    # Create init script symlink
    mkdir -p /etc/runlevels/default
    ln -sf /etc/init.d/network /etc/runlevels/default/network 2>/dev/null || true
    
    # Add PPPoE to interfaces
    if ! grep -q "pppoe" /etc/network/interfaces 2>/dev/null; then
        echo "auto pppoe" >> /etc/network/interfaces
        echo "iface pppoe inet ppp" >> /etc/network/interfaces
        echo "    provider pppoe" >> /etc/network/interfaces
    fi
    
    echo "PPPoE enabled on boot"
}

pppoe_disable() {
    echo "Disabling PPPoE auto-connect..."
    
    # Comment out pppoe in interfaces
    sed -i '/^auto pppoe/s/^/#/' /etc/network/interfaces 2>/dev/null || true
    sed -i '/^iface pppoe/s/^/#/' /etc/network/interfaces 2>/dev/null || true
    
    echo "PPPoE disabled on boot"
}

# Main
case "$1" in
    config)
        pppoe_config "$2" "$3"
        ;;
    connect)
        pppoe_connect
        ;;
    disconnect)
        pppoe_disconnect
        ;;
    status)
        pppoe_status
        ;;
    test)
        pppoe_test
        ;;
    enable)
        pppoe_enable
        ;;
    disable)
        pppoe_disable
        ;;
    *)
        usage
        exit 1
        ;;
esac