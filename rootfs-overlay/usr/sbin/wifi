#!/bin/sh
# WiFi configuration utility for JDCloud AX6600
# Similar to OpenWrt's wifi command

CONFIG_DIR="/etc/hostapd"
HOSTAPD_2G="${CONFIG_DIR}/hostapd.conf"
HOSTAPD_5G="${CONFIG_DIR}/hostapd-5g.conf"

usage() {
    echo "Usage: wifi <command> [options]"
    echo "Commands:"
    echo "  setup <ssid> <password>  - Configure WiFi SSID and password"
    echo "  up                       - Start WiFi interfaces"
    echo "  down                     - Stop WiFi interfaces"
    echo "  status                   - Show WiFi status"
    echo "  scan                     - Scan available networks"
    echo "  restart                  - Restart WiFi"
    echo "  channel <2g-ch> <5g-ch>  - Set WiFi channels"
    echo "  hide                     - Hide SSID (broadcast disabled)"
    echo "  show                     - Show SSID (broadcast enabled)"
}

wifi_setup() {
    local ssid="$1"
    local password="$2"
    
    if [ -z "$ssid" ] || [ -z "$password" ]; then
        echo "Error: SSID and password required"
        echo "Usage: wifi setup <ssid> <password>"
        exit 1
    fi
    
    if [ ${#password} -lt 8 ]; then
        echo "Error: Password must be at least 8 characters"
        exit 1
    fi
    
    # Configure 2.4GHz
    if [ -f "$HOSTAPD_2G" ]; then
        sed -i "s/^ssid=.*/ssid=${ssid}/" "$HOSTAPD_2G"
        sed -i "s/^wpa_passphrase=.*/wpa_passphrase=${password}/" "$HOSTAPD_2G"
        echo "Configured 2.4GHz: SSID=${ssid}"
    fi
    
    # Configure 5GHz
    if [ -f "$HOSTAPD_5G" ]; then
        sed -i "s/^ssid=.*/ssid=${ssid}-5G/" "$HOSTAPD_5G"
        sed -i "s/^wpa_passphrase=.*/wpa_passphrase=${password}/" "$HOSTAPD_5G"
        echo "Configured 5GHz: SSID=${ssid}-5G"
    fi
    
    echo "WiFi configured. Run 'wifi up' to apply changes."
}

wifi_up() {
    echo "Starting WiFi..."
    
    # Load ath11k firmware
    modprobe ath11k 2>/dev/null || echo "ath11k module loading..."
    
    # Wait for interfaces
    sleep 3
    
    # Check for interfaces
    if ! ip link show wlan0 2>/dev/null; then
        echo "Warning: wlan0 not found, waiting..."
        sleep 5
    fi
    
    # Start hostapd for 2.4GHz
    if [ -f "$HOSTAPD_2G" ]; then
        # Add wlan0 to bridge if not already
        ip link set wlan0 up 2>/dev/null
        brctl addif br-lan wlan0 2>/dev/null || true
        
        /usr/sbin/hostapd -B -P /var/run/hostapd-2g.pid "$HOSTAPD_2G" 2>/dev/null && \
            echo "2.4GHz AP started on wlan0" || \
            echo "Failed to start 2.4GHz AP"
    fi
    
    # Start hostapd for 5GHz
    if [ -f "$HOSTAPD_5G" ]; then
        # Check for wlan1 interface
        if ip link show wlan1 2>/dev/null; then
            ip link set wlan1 up 2>/dev/null
            brctl addif br-lan wlan1 2>/dev/null || true
            
            /usr/sbin/hostapd -B -P /var/run/hostapd-5g.pid "$HOSTAPD_5G" 2>/dev/null && \
                echo "5GHz AP started on wlan1" || \
                echo "Failed to start 5GHz AP"
        else
            echo "Warning: wlan1 not available for 5GHz"
        fi
    fi
    
    echo "WiFi started."
}

wifi_down() {
    echo "Stopping WiFi..."
    
    # Stop hostapd processes
    killall hostapd 2>/dev/null || true
    
    # Remove interfaces from bridge
    brctl delif br-lan wlan0 2>/dev/null || true
    brctl delif br-lan wlan1 2>/dev/null || true
    
    # Bring down interfaces
    ip link set wlan0 down 2>/dev/null || true
    ip link set wlan1 down 2>/dev/null || true
    
    echo "WiFi stopped."
}

wifi_status() {
    echo "=== WiFi Status ==="
    echo ""
    
    # Show interfaces
    echo "Interfaces:"
    ip link show wlan0 2>/dev/null && echo "  wlan0: available" || echo "  wlan0: not found"
    ip link show wlan1 2>/dev/null && echo "  wlan1: available" || echo "  wlan1: not found"
    echo ""
    
    # Show hostapd status
    echo "AP Status:"
    if pgrep -f "hostapd" > /dev/null; then
        echo "  hostapd: running"
        for pid_file in /var/run/hostapd-*.pid; do
            if [ -f "$pid_file" ]; then
                local pid=$(cat "$pid_file")
                echo "  PID: $pid ($(basename $pid_file))"
            fi
        done
    else
        echo "  hostapd: not running"
    fi
    echo ""
    
    # Show configuration
    echo "Configuration:"
    if [ -f "$HOSTAPD_2G" ]; then
        echo "  2.4GHz SSID: $(grep '^ssid=' $HOSTAPD_2G | cut -d= -f2)"
        echo "  2.4GHz Channel: $(grep '^channel=' $HOSTAPD_2G | cut -d= -f2)"
    fi
    if [ -f "$HOSTAPD_5G" ]; then
        echo "  5GHz SSID: $(grep '^ssid=' $HOSTAPD_5G | cut -d= -f2)"
        echo "  5GHz Channel: $(grep '^channel=' $HOSTAPD_5G | cut -d= -f2)"
    fi
    echo ""
    
    # Show connected clients (if hostapd_cli available)
    if command -v hostapd_cli > /dev/null 2>&1; then
        echo "Connected Clients:"
        hostapd_cli -i wlan0 list_sta 2>/dev/null | head -5 || echo "  No clients or hostapd_cli unavailable"
    fi
}

wifi_scan() {
    echo "Scanning WiFi networks..."
    
    # Ensure interface is up
    ip link set wlan0 up 2>/dev/null || true
    
    # Use iw to scan
    if command -v iw > /dev/null; then
        iw dev wlan0 scan 2>/dev/null | grep -E "SSID|signal|channel" | head -30
    else
        echo "iw command not available"
    fi
}

wifi_channel() {
    local ch2g="$1"
    local ch5g="$2"
    
    if [ -n "$ch2g" ] && [ -f "$HOSTAPD_2G" ]; then
        sed -i "s/^channel=.*/channel=${ch2g}/" "$HOSTAPD_2G"
        echo "2.4GHz channel set to $ch2g"
    fi
    
    if [ -n "$ch5g" ] && [ -f "$HOSTAPD_5G" ]; then
        sed -i "s/^channel=.*/channel=${ch5g}/" "$HOSTAPD_5G"
        echo "5GHz channel set to $ch5g"
    fi
    
    echo "Restart WiFi to apply: wifi restart"
}

wifi_hide() {
    [ -f "$HOSTAPD_2G" ] && sed -i 's/^ignore_broadcast_ssid=.*/ignore_broadcast_ssid=1/' "$HOSTAPD_2G"
    [ -f "$HOSTAPD_5G" ] && sed -i 's/^ignore_broadcast_ssid=.*/ignore_broadcast_ssid=1/' "$HOSTAPD_5G"
    echo "SSID hidden. Restart WiFi to apply."
}

wifi_show() {
    [ -f "$HOSTAPD_2G" ] && sed -i 's/^ignore_broadcast_ssid=.*/ignore_broadcast_ssid=0/' "$HOSTAPD_2G"
    [ -f "$HOSTAPD_5G" ] && sed -i 's/^ignore_broadcast_ssid=.*/ignore_broadcast_ssid=0/' "$HOSTAPD_5G"
    echo "SSID visible. Restart WiFi to apply."
}

wifi_restart() {
    wifi_down
    sleep 2
    wifi_up
}

# Main
case "$1" in
    setup)
        wifi_setup "$2" "$3"
        ;;
    up)
        wifi_up
        ;;
    down)
        wifi_down
        ;;
    status)
        wifi_status
        ;;
    scan)
        wifi_scan
        ;;
    channel)
        wifi_channel "$2" "$3"
        ;;
    hide)
        wifi_hide
        ;;
    show)
        wifi_show
        ;;
    restart)
        wifi_restart
        ;;
    *)
        usage
        exit 1
        ;;
esac