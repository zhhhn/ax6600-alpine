#!/bin/sh
# Port forwarding management for JDCloud AX6600
# Manages NAT port forwarding rules using nftables

RULES_FILE="/etc/port-forward.rules"
NFT_CONF="/etc/nftables.conf"

usage() {
    echo "Usage: port-forward <command> [options]"
    echo "Commands:"
    echo "  add <ext-port> <internal-ip> <int-port> [tcp|udp]  - Add rule"
    echo "  del <ext-port> [tcp|udp]                          - Delete rule"
    echo "  list                                              - List rules"
    echo "  clear                                             - Clear all rules"
    echo "  apply                                             - Apply rules to nftables"
    echo "  enable                                            - Enable port forwarding"
    echo "  disable                                           - Disable port forwarding"
}

ensure_rules_file() {
    [ ! -f "$RULES_FILE" ] && touch "$RULES_FILE"
}

pf_add() {
    local ext_port="$1"
    local int_ip="$2"
    local int_port="$3"
    local proto="${4:-tcp}"
    
    if [ -z "$ext_port" ] || [ -z "$int_ip" ] || [ -z "$int_port" ]; then
        echo "Error: Missing parameters"
        echo "Usage: port-forward add <ext-port> <internal-ip> <int-port> [tcp|udp]"
        exit 1
    fi
    
    # Validate IP format
    if ! echo "$int_ip" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$'; then
        echo "Error: Invalid IP address format"
        exit 1
    fi
    
    # Validate port numbers
    if [ "$ext_port" -lt 1 ] || [ "$ext_port" -gt 65535 ] 2>/dev/null; then
        echo "Error: Invalid external port (1-65535)"
        exit 1
    fi
    if [ "$int_port" -lt 1 ] || [ "$int_port" -gt 65535 ] 2>/dev/null; then
        echo "Error: Invalid internal port (1-65535)"
        exit 1
    fi
    
    ensure_rules_file
    
    # Check for duplicate
    if grep -q "^${proto}:${ext_port}:" "$RULES_FILE"; then
        echo "Warning: Rule already exists for ${proto}:${ext_port}"
        exit 1
    fi
    
    # Add rule
    echo "${proto}:${ext_port}:${int_ip}:${int_port}" >> "$RULES_FILE"
    echo "Added: ${proto} port ${ext_port} -> ${int_ip}:${int_port}"
    
    # Apply immediately
    pf_apply
}

pf_del() {
    local ext_port="$1"
    local proto="${2:-tcp}"
    
    if [ -z "$ext_port" ]; then
        echo "Error: Missing external port"
        echo "Usage: port-forward del <ext-port> [tcp|udp]"
        exit 1
    fi
    
    ensure_rules_file
    
    if ! grep -q "^${proto}:${ext_port}:" "$RULES_FILE"; then
        echo "Warning: No rule found for ${proto}:${ext_port}"
        exit 1
    fi
    
    # Delete rule
    sed -i "/^${proto}:${ext_port}:/d" "$RULES_FILE"
    echo "Deleted: ${proto} port ${ext_port}"
    
    # Apply immediately
    pf_apply
}

pf_list() {
    ensure_rules_file
    
    echo "=== Port Forwarding Rules ==="
    echo "Format: proto:external:internal-ip:internal"
    echo ""
    
    if [ -s "$RULES_FILE" ]; then
        while IFS=: read proto ext_port int_ip int_port; do
            echo "${proto}:${ext_port} -> ${int_ip}:${int_port}"
        done < "$RULES_FILE"
    else
        echo "No rules configured"
    fi
}

pf_clear() {
    ensure_rules_file
    > "$RULES_FILE"
    echo "All port forwarding rules cleared"
    pf_apply
}

pf_apply() {
    ensure_rules_file
    
    echo "Applying port forwarding rules..."
    
    # Create nftables rules for port forwarding
    local NFT_PORT_FORWARD="/tmp/nft-port-forward.rules"
    
    echo "# Port forwarding rules (auto-generated)" > "$NFT_PORT_FORWARD"
    
    if [ -s "$RULES_FILE" ]; then
        while IFS=: read proto ext_port int_ip int_port; do
            echo "add rule ip nat prerouting ${proto} dport ${ext_port} dnat to ${int_ip}:${int_port}" >> "$NFT_PORT_FORWARD"
            echo "add rule inet filter forward ${proto} dport ${int_port} ip daddr ${int_ip} accept" >> "$NFT_PORT_FORWARD"
        done < "$RULES_FILE"
    fi
    
    # Apply rules to nftables
    if [ -s "$NFT_PORT_FORWARD" ] && command -v nft > /dev/null; then
        # First delete old port-forward rules if any
        nft delete table ip nat-forward 2>/dev/null || true
        
        # Create new table for port forwarding
        nft add table ip nat-forward 2>/dev/null || true
        nft add chain ip nat-forward prerouting { type nat hook prerouting priority 0 \; } 2>/dev/null || true
        
        while read rule; do
            [ -n "$rule" ] && [ "$rule" != "# Port forwarding rules (auto-generated)" ] && \
                nft "$rule" 2>/dev/null || true
        done < "$NFT_PORT_FORWARD"
        
        echo "Rules applied successfully"
    else
        echo "No rules to apply or nft not available"
    fi
    
    rm -f "$NFT_PORT_FORWARD"
}

pf_enable() {
    echo "Port forwarding enabled (automatic with pf_apply)"
    pf_apply
}

pf_disable() {
    echo "Disabling port forwarding..."
    nft delete table ip nat-forward 2>/dev/null || true
    echo "Port forwarding disabled"
}

# Main
case "$1" in
    add)
        pf_add "$2" "$3" "$4" "$5"
        ;;
    del)
        pf_del "$2" "$3"
        ;;
    list)
        pf_list
        ;;
    clear)
        pf_clear
        ;;
    apply)
        pf_apply
        ;;
    enable)
        pf_enable
        ;;
    disable)
        pf_disable
        ;;
    *)
        usage
        exit 1
        ;;
esac